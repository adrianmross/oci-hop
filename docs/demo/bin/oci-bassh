#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  explain)
    cat <<'JSON'
{
  "host": "app-server-01",
  "ok": true,
  "ssh_config": {
    "hostname": "10.0.1.25",
    "user": "cloud-user",
    "proxyjump": "dev-bastion"
  }
}
JSON
    ;;
  ensure)
    cat <<'JSON'
{
  "ok": true,
  "action": "reused_active_session",
  "ssh_target": "app-server-01",
  "connect": "ssh app-server-01"
}
JSON
    ;;
  paths)
    cat <<'JSON'
{
  "binary": "/opt/homebrew/bin/oci-bassh",
  "ssh_include": "~/.ssh/config.d/bastion-session",
  "tracked_targets": "~/.cache/bastion-session/tracked-targets.json"
}
JSON
    ;;
  *)
    echo "oci-bassh demo shim: unsupported command" >&2
    exit 2
    ;;
esac
