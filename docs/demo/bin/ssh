#!/usr/bin/env bash
set -euo pipefail

host="${1:-}"
if [[ "$host" != "my-vps-01" ]]; then
  echo "ssh demo shim: unsupported host" >&2
  exit 2
fi

cat <<'OUT'
Last login: Tue May 19 02:12:00 2026
OUT
printf '\033[38;5;81m[cloud-user@my-vps-01 ~]$ \033[0mhostname\n'
cat <<'OUT'
my-vps-01
OUT
printf '\033[38;5;81m[cloud-user@my-vps-01 ~]$ \033[0mexit\n'
